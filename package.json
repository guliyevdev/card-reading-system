{
  "name": "card-reading-system",
  "version": "1.0.0",
  "description": "Card reading system for azerpost",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "build": "npm run build:win",
    "build:win": "pkg . --targets node18-win-x64 --output dist/SmartCardReader-win-x64.exe",
    "build:mac:intel": "pkg . --targets node18-macos-x64 --output dist/SmartCardReader-macos-x64",
    "build:mac:arm": "pkg . --targets node18-macos-arm64 --output dist/SmartCardReader-macos-arm64",
    "build:all": "npm run build:win && npm run build:mac:intel && npm run build:mac:arm",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "nodemon": "^3.1.11",
    "pcsclite": "^1.0.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
